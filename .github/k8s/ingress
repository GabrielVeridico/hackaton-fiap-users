apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: fgc-users-ingress
  namespace: fcg
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
    nginx.ingress.kubernetes.io/proxy-body-size: "10m"
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /api/users
            pathType: Prefix
            backend:
              service:
                name: fgc-users-svc
                port:
                  number: 80
          - path: /api/auth
            pathType: Prefix
            backend:
              service:
                name: fgc-users-svc
                port:
                  number: 80
